# ========================================
# PROTECT VIDEOS FOLDER
# Prevent PHP execution and directory browsing
# ========================================

# DISABLE DIRECTORY BROWSING
Options -Indexes

# DISABLE PHP EXECUTION (Videos folder should only contain video files)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# BLOCK PHP FILES FROM BEING ACCESSED/EXECUTED
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# SET CORRECT MIME TYPES FOR VIDEOS
<IfModule mod_mime.c>
    AddType video/mp4 .mp4
    AddType video/webm .webm
    AddType video/ogg .ogv
    AddType video/quicktime .mov
</IfModule>

# PREVENT ACCESS TO SENSITIVE FILES
<FilesMatch "^(\.htaccess|\.htpasswd|\.git|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
