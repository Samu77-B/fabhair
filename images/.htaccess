# ========================================
# PROTECT IMAGES FOLDER
# Prevent PHP execution and directory browsing
# ========================================

# DISABLE DIRECTORY BROWSING
Options -Indexes

# DISABLE PHP EXECUTION (Images folder should only contain image files)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# BLOCK PHP FILES FROM BEING ACCESSED/EXECUTED
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# SET CORRECT MIME TYPES FOR IMAGES
<IfModule mod_mime.c>
    AddType image/jpeg .jpg .jpeg
    AddType image/png .png
    AddType image/gif .gif
    AddType image/webp .webp
    AddType image/svg+xml .svg
</IfModule>

# PREVENT ACCESS TO SENSITIVE FILES
<FilesMatch "^(\.htaccess|\.htpasswd|\.git|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
