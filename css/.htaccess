# ========================================
# PROTECT CSS FOLDER
# Prevent PHP execution and directory browsing
# ========================================

# DISABLE DIRECTORY BROWSING
Options -Indexes

# DISABLE PHP EXECUTION (CSS folder should only contain stylesheets)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# BLOCK PHP FILES FROM BEING ACCESSED/EXECUTED
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# SET CORRECT MIME TYPES
<IfModule mod_mime.c>
    AddType text/css .css
</IfModule>
